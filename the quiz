              "Bewusst androgyne Wirkung"
            ]
          }
        }
      },

      male: {
        title: "Entscheidungsbaum – Männer",
        questions: {
          start: {
            text: "Welche Stilrichtung passt am ehesten zu dir?",
            options: [
