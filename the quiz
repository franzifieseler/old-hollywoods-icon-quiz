              { label: "Lässig, maskulin und moderner", next: "male_casual" }
            ]
          },
          male_classic: {
            text: "Was ist dir wichtiger?",
            options: [
              { label: "Grau-Flanell, natürliche Schulter, zeitlos", result: "cary" },
              { label: "Doppelreiher, breite Revers, Krawatte und Einstecktuch", result: "gable" }
            ]
