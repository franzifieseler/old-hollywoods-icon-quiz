              { label: "Eleganter, aber immer noch eher reduziert", result: "bacall" }
            ]
          }
        },
        results: {
          audrey: {
            icon: "Audrey Hepburn",
            subtitle: "Schlichte Eleganz mit ikonischem Chic",
            vibe: "Ideal, wenn du ein kleines Schwarzes, Perlen, Ballerinas oder eine elegante Hochsteckfrisur bevorzugst.",
            outfit: [
              "Kleines Schwarzes, schulterfrei oder hochgeschlossen",
              "Perlenkette oder Perlenohrringe",
