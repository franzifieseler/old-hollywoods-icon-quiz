          },
          male_casual: {
            text: "Welche Art von Lässigkeit passt besser?",
            options: [
              { label: "Weißes T-Shirt, Lederjacke, Jeans", result: "brando" },
              { label: "Weißes T-Shirt, roter Blouson, rebellischer Look", result: "jamesdean" }
            ]
          }
        },
        results: {
          cary: {
            icon: "Cary Grant",
            subtitle: "Zeitloser Gentleman mit perfekter Balance",
            vibe: "Ideal, wenn du klassische Eleganz willst, ohne übertrieben formell zu wirken.",
            outfit: [
              "Grau-Flanell-Anzug mit natürlicher Schulter",
              "Saubere, schlanke Linie ohne modische Extreme",
              "Weißes Hemd und klassische Krawatte",
              "Zurückhaltende, hochwertige Accessoires"
            ],
            beauty: [
              "Gepflegte Haare mit sauberem Styling",
              "Klassische Gentleman-Ausstrahlung",
              "Keine Überladung, alles sitzt perfekt",
              "Sehr harmonischer Gesamtlook"
            ]
          },
          bogart: {
            icon: "Humphrey Bogart",
            subtitle: "Cooler Gentleman mit Film-noir-Aura",
            vibe: "Perfekt, wenn du den Fedora-Trenchcoat-Anzug-Look von Casablanca aufgreifen willst.",
            outfit: [
              "Perfekt sitzender Anzug",
              "Fedora als Schlüsselaccessoire",
              "Trenchcoat für den ikonischen Auftritt",
              "Klassische Lederschuhe"
            ],
            beauty: [
              "Scharfe, klare Linien im Styling",
              "Zurückhaltend, aber sehr präsent",
              "Eher dunkel und elegant statt verspielt",
              "Filmischer Gesamtcharakter"
            ]
          },
          gable: {
            icon: "Clark Gable",
            subtitle: "Starkes Tailoring mit klassischer Autorität",
            vibe: "Richtig für dich, wenn du Doppelreiher, breite Revers und klassische Männermode der Ära liebst.",
            outfit: [
              "Doppelreihiger Anzug oder Dreiteiler",
              "Breite Revers und hohe Bundfalten",
              "Krawatte und Einstecktuch",
              "Dunkelblau, Anthrazit oder Grau-Flanell"
            ],
            beauty: [
              "Sehr gepflegtes Haar",
              "Souveräne, formelle Ausstrahlung",
              "Kein Casual-Bruch",
              "Klassischer Abend-Look"
            ]
          },
          sinatra: {
            icon: "Frank Sinatra",
            subtitle: "Raffinierter Abendglamour mit Persönlichkeit",
            vibe: "Die beste Option, wenn du sehr stilvoll, leicht showmanhaft und abendtauglich erscheinen willst.",
            outfit: [
              "Anthrazitfarbener Dreiteiler oder Smoking",
              "Trilby-Hut",
              "Hohe Bundfalten",
              "Opera Pumps oder besonders elegante Schuhe"
            ],
            beauty: [
              "Souveränes, charmantes Auftreten",
              "Perfekt abgestimmte Accessoires",
              "Abendlook mit Charakter",
              "Klassisch, aber nicht steif"
            ]
          },
          astaire: {
            icon: "Fred Astaire",
            subtitle: "Höchste Form der formellen Eleganz",
            vibe: "Für maximale Dresscode-Interpretation mit White Tie und tänzerischer Leichtigkeit.",
            outfit: [
              "White Tie and Tails",
              "Formellster Look des Abends",
              "Makelloses Hemd und edle Schuhe",
              "Sehr präzise, festliche Gesamtwirkung"
            ],
            beauty: [
              "Extrem gepflegtes Finish",
              "Leichtigkeit trotz Formalität",
              "Eleganter als businesshaft",
              "Old Hollywood in Reinform"
            ]
          },
          mcqueen: {
            icon: "Steve McQueen",
            subtitle: "Minimalistisch, funktional und cool",
            vibe: "Gut, wenn du Old Hollywood modern und entspannter interpretieren willst.",
            outfit: [
              "Khakis oder schlichte Hose",
              "Kaschmir-Pullover oder Rollkragen",
              "Chukka Boots",
              "Reduzierte, maskuline Basics"
            ],
            beauty: [
              "Unprätentiöses Grooming",
              "Lässige, kontrollierte Coolness",
              "Weniger Accessoires",
              "Modernere Übersetzung des Mottos"
            ]
          },
          brando: {
            icon: "Marlon Brando",
            subtitle: "Moderne Männlichkeit mit rauer Kante",
            vibe: "Passt, wenn du es eher casual halten möchtest, aber trotzdem ikonisch auftreten willst.",
            outfit: [
              "Weißes T-Shirt",
              "Lederjacke",
              "Jeans",
              "Schlichte Boots oder Lederschuhe"
            ],
            beauty: [
              "Zweckmäßiges Styling",
              "Selbstbewusste Lässigkeit",
              "Kein überformeller Eindruck",
              "Reduziert und markant"
            ]
          },
          jamesdean: {
            icon: "James Dean",
            subtitle: "Rebellische Lässigkeit mit jugendlichem Charisma",
            vibe: "Ideal, wenn du den nonkonformistischen, entspannten Look der Ära bevorzugst.",
            outfit: [
              "Weißes T-Shirt",
              "Roter Blouson oder Lederjacke",
              "Schmale Jeans",
              "Schlichte, lässige Schuhe"
            ],
            beauty: [
              "Zerzaustes Haar",
              "Jugendlicher, rebellischer Ausdruck",
              "Weniger geschniegelt, mehr Attitude",
              "Casual mit ikonischer Wirkung"
            ]
          }
        }
      }
    };

    let currentGender = "female";
    let currentNode = "start";
    let currentPath = [];

    const treeEl = document.getElementById("tree");
    const resultEl = document.getElementById("result");
    const pathEl = document.getElementById("path");
    const genderButtons = document.querySelectorAll(".gender-btn");

    function renderPath() {
      pathEl.innerHTML = currentPath
        .map(step => `<span class="chip">${step}</span>`)
        .join("");
    }

    function renderQuestion() {
      const config = data[currentGender];
      const question = config.questions[currentNode];
      resultEl.classList.remove("show");
      resultEl.innerHTML = "";

      treeEl.innerHTML = `
        <div class="question-box">
          <h2 class="question-title">${config.title}</h2>
          <p>${question.text}</p>
          <div class="options">
            ${question.options.map((option, index) => `
              <button class="option-btn" data-index="${index}">
                ${option.label}
              </button>
            `).join("")}
          </div>
        </div>
      `;

      treeEl.querySelectorAll(".option-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const option = question.options[Number(btn.dataset.index)];
          currentPath.push(option.label);
          renderPath();

          if (option.result) {
            renderResult(option.result);
          } else {
            currentNode = option.next;
            renderQuestion();
          }
        });
      });
    }

    function renderResult(resultKey) {
      const result = data[currentGender].results[resultKey];

      resultEl.innerHTML = `
        <h2>Deine Ikone: ${result.icon}</h2>
        <p class="subtitle">${result.subtitle}</p>
        <p class="result-note">${result.vibe}</p>

        <div class="result-grid">
          <div class="result-card">
            <h3>Outfit</h3>
            <ul>
              ${result.outfit.map(item => `<li>${item}</li>`).join("")}
            </ul>
          </div>
          <div class="result-card">
            <h3>Beauty / Styling</h3>
            <ul>
              ${result.beauty.map(item => `<li>${item}</li>`).join("")}
            </ul>
          </div>
        </div>

        <button class="restart-btn" id="restartBtn">Neu starten</button>
      `;

      resultEl.classList.add("show");

      document.getElementById("restartBtn").addEventListener("click", () => {
        currentNode = "start";
        currentPath = [];
        renderPath();
        renderQuestion();
      });
    }

    function switchGender(gender) {
      currentGender = gender;
      currentNode = "start";
      currentPath = [];
      renderPath();
      renderQuestion();

      genderButtons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.gender === gender);
      });
    }

    genderButtons.forEach(btn => {
      btn.addEventListener("click", () => switchGender(btn.dataset.gender));
    });

    renderQuestion();
  </script>
</body>
</html>
